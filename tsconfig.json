{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@pages/*": ["src/pages/*"],
      "@assets/*": ["src/assets/*"],
      "@css": ["src/styles/global.css"],
      "@types": ["src/types.d.ts"]
    }
  },
  "include": [
    ".astro/**/*.d.ts",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.astro",
    "src/**/*.svelte",
    "./worker-configuration.d.ts",
    "src/pages/rss.xml.ts",
    "src/pages/rss.xml.ts"
  ]
}
