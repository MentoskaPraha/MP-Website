{
  "extends": "astro/tsconfigs/strict",
  "strictNullChecks": true,
  "allowJs": true,
  "compilerOptions": {
    "jsx": "preserve",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@pages/*": ["src/pages/*"],
      "@images/*": ["src/images/*"],
      "@css": ["src/styles/global.css"]
    }
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.astro",
    "src/**/*.svelte"
  ]
}
