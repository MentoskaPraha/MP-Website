---
import AboutBox from "@components/AboutBox.svelte";
import ItemDisplay from "@components/ItemDisplay.svelte";
import { getCollection } from "astro:content";
import type { ItemDisplayItem } from "@types";
import Layout from "@layouts/Global.astro";

const technology = (await getCollection("technology")).map((entry) => {
  return {
    id: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    link: entry.data.link
  } as ItemDisplayItem;
});

const games = (await getCollection("games")).map((entry) => {
  return {
    id: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    link: entry.data.link
  } as ItemDisplayItem;
});
---

<Layout
  title="About"
  description="This page is all about me! That sound egomaniacal. It's not supposed to, this is just a convenient way for you to get to know me."
>
  <AboutBox client:visible />

  <div class="mt-8">
    <h2 class="text-center text-3xl font-bold underline mb-3">
      Technology I Use for Development
    </h2>
    <ItemDisplay
      images={import.meta.glob<{ default: ImageMetadata }>(
        "/src/assets/technology/*.{webp,svg}",
        {
          eager: true
        }
      )}
      items={technology}
      client:visible
    />
  </div>

  <div class="mt-8">
    <h2 class="text-center text-3xl font-bold underline mb-3">
      Games I Play and Enjoy
    </h2>
    <ItemDisplay
      images={import.meta.glob<{ default: ImageMetadata }>(
        "/src/assets/games/*.{webp,svg}",
        {
          eager: true
        }
      )}
      items={games}
      client:visible
    />
  </div>
</Layout>
