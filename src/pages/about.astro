---
import Root from "@layouts/Root.astro";
import Navbar from "@components/Navbar.svelte";
import AboutBox from "@components/AboutBox.svelte";
---

<Root
  title="About"
  description="This page is all about me! That sound egomaniacal. It's not supposed to, this is just a convenient way for you to get to know me."
>
  <Navbar client:load />
  <AboutBox client:visible />

  <div class="mt-8">
    <h2 class="text-center text-3xl font-bold underline">Technology I Use</h2>
  </div>

  <div>
    <h2>Games I Enjoy</h2>
    Might be useful to grab this from Steam?
  </div>
</Root>
