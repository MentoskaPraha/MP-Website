---
import Layout from "@layouts/Global.astro";
import ProjectBox from "@components/ProjectBox.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");

const images = Object.fromEntries(
  Object.entries(
    import.meta.glob<{ default: ImageMetadata }>(
      "/src/assets/projects/*.{webp,svg}",
      {
        eager: true
      }
    )
  ).map(([path, value]) => {
    const key = path
      .split("/")
      .at(-1)!
      .replace(/\.[^.]+$/, "");
    return [key, value];
  })
);
---

<Layout
  title="Projects"
  description="Browse through some of the amazing projects that I have created."
>
  <h2 class="text-center text-3xl font-bold underline my-4">Projects</h2>
  {
    projects.map((entry) => (
      <ProjectBox
        title={entry.data.title}
        description={entry.data.description}
        link={entry.data.link}
        code={entry.data.code}
        image={images[entry.data.id]?.default.src}
      />
    ))
  }
</Layout>
