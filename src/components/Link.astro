---
import { Image } from "astro:assets";

interface Props {
  title: string;
  link: string;
  image: ImageMetadata;
}

const { title, link, image } = Astro.props;
---

<a href={link} target="_blank" rel="noopener noreferrer">
  <div
    id="container"
    class="w-16 relative inline-block rounded-full group border-4 border-black"
  >
    <Image
      class="w-full h-auto bg-white rounded-full"
      src={image}
      width="64"
      height="64"
      alt=`${title} link icon`
    />
    <span
      id="tooltip"
      class="w-28 top-full left-1/2 mt-1.5 -ml-14 bg-gray-600 text-white text-center px-0.5 absolute rounded-sm z-10 opacity-0 group-hover:opacity-100 transition-opacity"
    >
      {title}
    </span>
  </div>
</a>
