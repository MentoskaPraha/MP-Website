---
import Layout from "@layouts/Root.astro";
import Navbar from "@components/Navbar.svelte";
import Footer from "@components/Footer.astro";

//setup props
interface Props {
  title?: string;
  siteTitle?: string;
  description: string;
}

const { title, siteTitle, description } = Astro.props;
---

<Layout title={title} siteTitle={siteTitle} description={description}>
  <Navbar client:load />
  <slot />
  <Footer />
</Layout>
